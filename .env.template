# Google OAuth2 credentials (fill these from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
# Redirect URI used when creating credentials, default uses out-of-band
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
# Path to store token after authorization (relative to repo)
GOOGLE_TOKEN_PATH=.google_token.json
